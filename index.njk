---
title: "DiscoAvaliadoBR - Site de críticas de álbuns"
---
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/Imagens/favicon.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <title>{{ title }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">
<style>
    :root { --bg: #f8f6f2; --text: #111; }
    body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); }
    header { 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        padding: 22px 50px;  
        background: #fff; 
        border-bottom: 1px solid var(--border-color); 
        position: sticky; 
        top: 0; 
        z-index: 9999; 
    }
    .logo { 
        font-family: 'Playfair Display', serif; 
        font-size: 26px;  
        font-weight: 700; 
        text-decoration: none; 
        color: var(--text); 
    }
    a { 
        text-decoration: none; 
        color: inherit; 
    }
    .container { 
        max-width: 1100px; 
        margin: 60px auto; 
        padding: 0 20px; 
    }
    .album-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
        gap: 25px; 
    }
    .album-card { 
        text-align: center; 
        transition: 0.3s; 
        margin-bottom: 20px; 
    }
    .album-card:hover { 
        transform: translateY(-5px); 
    }
    .album-card img { 
        width: 100%; 
        height: 200px;  
        object-fit: cover; 
        border-radius: 10px; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.08); 
    }
    .album-card h3 { 
        font-family: 'Playfair Display'; 
        font-size: 17px; 
        margin: 12px 0 4px; 
        color: var(--text); 
    }
    .album-card p { 
        margin: 0; 
        font-size: 13px; 
        color: #666; 
    }
    nav a { 
        font-weight: 600; 
        font-size: 14px; 
    }
    footer {
        margin-top: 100px;
        padding: 60px 20px;
        text-align: center;
        background: white;
        border-top: 1px solid var(--border-color);
        color: #888;
        font-size: 13px;
    }
</style>
</head>
<body>
<header>
    <a href="/" class="logo">DiscoAvaliadoBR</a>
</header>
<main class="container">
    <h2>Críticas a álbuns de 2026</h2>
    <div class="album-grid">
        {% for item in collections.tudo2026 %}
            <a href="{{ item.url }}" class="album-card">
                <img src="{{ item.data.imagem }}" alt="{{ item.data.album }}">
                <h3>{{ item.data.album }}</h3>
                <p>{{ item.data.artista }}</p>
            </a>
        {% endfor %}
    </div>

    <h2>Críticas a álbuns de 2025 e anteriores</h2>
    <div class="album-grid">
        {% for disco in collections.discosArquivados %}
            <a href="{{ disco.url }}" class="album-card">
                <img src="{{ disco.data.imagem }}" alt="{{ disco.data.album }}">
                <h3>{{ disco.data.album }}</h3>
                <p>{{ disco.data.artista }}</p>
            </a>
        {% endfor %}
    </div>
</main>
<footer>
    DiscoAvaliadoBR © 2026 • Projeto independente de crítica musical brasileira<br>
    Todos os direitos reservados.
</footer>
</body>
</html>

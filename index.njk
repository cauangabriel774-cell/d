---
title: "DiscoAvaliadoBR • Acervo"
---
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">

<style>
    :root { --bg: #f8f6f2; --text: #111; }
    body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); }
    
    /* HEADER COM BUSCA */
    header { 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        padding: 22px 50px;  /* Ajuste de padding */
        background: #fff; 
        border-bottom: 1px solid var(--border-color); /* Ajuste da borda */
        position: sticky; 
        top: 0; 
        z-index: 9999; 
    }

    .logo { 
        font-family: 'Playfair Display', serif; 
        font-size: 26px;  /* Ajuste do tamanho da fonte */
        font-weight: 700; 
        text-decoration: none; 
        color: var(--text); 
    }
    
    .search-wrapper { 
        position: relative; 
        width: 300px;  /* Ajuste do tamanho do campo de busca */
    }

    #top-search {
        width: 100%; 
        padding: 8px 15px; /* Ajuste de padding */
        border-radius: 20px;  /* Ajuste do raio da borda */
        border: 1px solid #ddd; 
        outline: none; 
        font-size: 14px;
    }

    #search-results {
        position: absolute; 
        top: 45px; 
        left: 0; 
        right: 0;
        background: white; 
        border-radius: 8px; /* Ajuste do raio da borda */
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        max-height: 400px; 
        overflow-y: auto; 
        display: none;
    }

    /* REMOVENDO O AZUL DOS LINKS */
    a { 
        text-decoration: none; 
        color: inherit; 
    }

    .result-item { 
        display: flex; 
        align-items: center; 
        padding: 10px; 
        border-bottom: 1px solid #eee; 
    }

    .result-item img { 
        width: 40px; 
        height: 40px; 
        border-radius: 4px; 
        object-fit: cover; 
        margin-right: 12px; 
    }

    /* GRID DE ÁLBUNS */
    .container { 
        max-width: 1100px; 
        margin: 60px auto; 
        padding: 0 20px; 
    }

    .album-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
        gap: 25px; 
    }

    .album-card { 
        text-align: center; 
        transition: 0.3s; 
        margin-bottom: 20px; 
    }

    .album-card:hover { 
        transform: translateY(-5px); 
    }

    .album-card img { 
        width: 100%; 
        height: 200px;  /* Ajuste de altura */
        object-fit: cover; 
        border-radius: 10px; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.08); 
    }

    .album-card h3 { 
        font-family: 'Playfair Display'; 
        font-size: 17px; 
        margin: 12px 0 4px; 
        color: var(--text); 
    }

    .album-card p { 
        margin: 0; 
        font-size: 13px; 
        color: #666; 
    }

    nav a { 
        font-weight: 600; 
        font-size: 14px; 
    }
</style>
</head>

<body>

<header>
    <a href="/" class="logo">DiscoAvaliadoBR</a>
    <div class="search-wrapper">
        <input type="text" id="top-search" placeholder="Pesquisar disco ou artista..." onkeyup="doSearch()">
        <div id="search-results"></div>
    </div>
    <nav><a href="/sobre">Sobre</a></nav>
</header>

<main class="container">
    <h2 style="font-family: 'Playfair Display'; margin-bottom: 30px;">Últimas Avaliações</h2>

    <div class="album-grid">
    {% for disco in collections.meusDiscos %}
        <a href="{{ disco.url }}" class="album-card">
            <img src="{{ disco.data.imagem }}" alt="{{ disco.data.album }}">
            <h3>{{ disco.data.album }}</h3>
            <p>{{ disco.data.artista }}</p>
        </a>
    {% endfor %}
</div>
</main>

<script>
    const searchData = [
        {% for item in collections.all %}
            {% if item.data.artista %}
            {
                title: "{{ item.data.album or item.data.artista }}",
                subtitle: "{{ item.data.artista if item.data.album else 'Página do Artista' }}",
                url: "{{ item.url }}",
                img: "{{ item.data.imagem or item.data.foto_artista }}"
            },
            {% endif %}
        {% endfor %}
    ];

    function searchSite() {
        const input = document.getElementById('global-search');
        const resultsBox = document.getElementById('search-results-box');
        if (!input || !resultsBox) return;

        const filter = input.value.toLowerCase();
        
        if (filter.length < 2) {
            resultsBox.style.display = 'none';
            return;
        }

        const filtered = searchData.filter(item => 
            item.title.toLowerCase().includes(filter) || 
            item.subtitle.toLowerCase().includes(filter)
        ).slice(0, 10);

        if (filtered.length > 0) {
            resultsBox.innerHTML = filtered.map(item => `
                <a href="${item.url}" class="search-item-result">
                    <img src="${item.img || '/Imagens/default.png'}" alt="">
                    <div>
                        <strong>${item.title}</strong>
                        <span>${item.subtitle}</span>
                    </div>
                </a>
            `).join('');
            resultsBox.style.display = 'block';
        } else {
            resultsBox.style.display = 'none';
        }
    }

    // Fecha a busca se clicar fora
    document.addEventListener('click', function(e) {
        const container = document.querySelector('.search-container');
        const resultsBox = document.getElementById('search-results-box');
        if (container && !container.contains(e.target)) {
            resultsBox.style.display = 'none';
        }
</script>

---
title: "DiscoAvaliadoBR • Acervo"
---
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <style>
        :root { --bg: #f8f6f2; --text: #111; }
        body { margin: 0; font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); }
        
        /* HEADER COM BUSCA */
        header { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 12px 5%; background: #fff; border-bottom: 1px solid #ddd; 
            position: sticky; top: 0; z-index: 9999; 
        }

        .logo { font-family: 'Playfair Display', serif; font-size: 22px; font-weight: 700; text-decoration: none; color: var(--text); }
        
        .search-wrapper { position: relative; width: 350px; }
        #top-search {
            width: 100%; padding: 10px 20px; border-radius: 25px; 
            border: 1px solid #ccc; outline: none; font-size: 14px;
        }

        #search-results {
            position: absolute; top: 45px; left: 0; right: 0;
            background: white; border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            max-height: 400px; overflow-y: auto; display: none;
        }

        /* REMOVENDO O AZUL DOS LINKS */
        a { text-decoration: none; color: inherit; }

        .result-item { display: flex; align-items: center; padding: 10px; border-bottom: 1px solid #eee; }
        .result-item img { width: 40px; height: 40px; border-radius: 4px; object-fit: cover; margin-right: 12px; }

        /* GRID DE ÁLBUNS */
        .container { max-width: 1100px; margin: 40px auto; padding: 0 20px; }
        .album-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); 
            gap: 25px; 
        }

        .album-card { text-align: center; transition: 0.3s; margin-bottom: 20px; }
        .album-card:hover { transform: translateY(-5px); }
        .album-card img { width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.08); }
        .album-card h3 { font-family: 'Playfair Display'; font-size: 17px; margin: 12px 0 4px; color: var(--text); }
        .album-card p { margin: 0; font-size: 13px; color: #666; }

        nav a { font-weight: 600; font-size: 14px; }
    </style>
</head>
<body>

<header>
    <a href="/" class="logo">DiscoAvaliadoBR</a>
    <div class="search-wrapper">
        <input type="text" id="top-search" placeholder="Pesquisar disco ou artista..." onkeyup="doSearch()">
        <div id="search-results"></div>
    </div>
    <nav><a href="/sobre">Sobre</a></nav>
</header>

<main class="container">
    <h2 style="font-family: 'Playfair Display'; margin-bottom: 30px;">Últimas Avaliações</h2>

    <div class="album-grid">
    {% for disco in collections.meusDiscos %}
        <a href="{{ disco.url }}" class="album-card">
            <img src="{{ disco.data.imagem }}" alt="{{ disco.data.album }}">
            <h3>{{ disco.data.album }}</h3>
            <p>{{ disco.data.artista }}</p>
        </a>
    {% endfor %}
</div>
</main>

<script>
    // Banco de dados completo para a busca (mostra TUDO que existir)
    const database = [
        {% for item in collections.all %}
            {% if item.data.album %}
            {
                title: "{{ item.data.album }}",
                artist: "{{ item.data.artista }}",
                url: "{{ item.url }}",
                img: "{{ item.data.imagem }}"
            },
            {% endif %}
        {% endfor %}
    ];

    function doSearch() {
        const searchQuery = document.getElementById("top-search").value.toLowerCase();
        const searchResults = document.getElementById("search-results");

        // Se a pesquisa for muito curta, esconde os resultados
        if (searchQuery.length < 3) {
            searchResults.style.display = 'none';
            return;
        }

        // Limpar resultados antigos
        searchResults.innerHTML = '';

        // Filtrando os álbuns que correspondem ao termo de pesquisa
        const filteredResults = database.filter(item => 
            item.title.toLowerCase().includes(searchQuery) || 
            item.artist.toLowerCase().includes(searchQuery)
        );

        if (filteredResults.length > 0) {
            searchResults.style.display = 'block';
            filteredResults.forEach(item => {
                const resultItem = document.createElement('div');
                resultItem.classList.add('result-item');
                resultItem.innerHTML = `
                    <a href="${item.url}">
                        <img src="${item.img}" alt="${item.title}">
                        <div>
                            <h4>${item.title}</h4>
                            <p>${item.artist}</p>
                        </div>
                    </a>
                `;
                searchResults.appendChild(resultItem);
            });
        } else {
            searchResults.style.display = 'none'; // Nenhum resultado encontrado
        }
    }
</script>

---
layout: layout.njk
title: Home
---

<div class="container">

    <div class="search-container-home" style="margin-bottom: 40px; text-align: center;">
        <input type="text" id="home-search" placeholder="Pesquisar álbum ou artista na página..." 
               onkeyup="searchHome()"
               style="width: 100%; max-width: 500px; padding: 15px 25px; border-radius: 30px; border: 1px solid #e5e2d9; outline: none; font-size: 16px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); font-family: 'Inter', sans-serif;">
    </div>

    <h2 class="section-title">Avaliados da Semana</h2>

    <div class="carousel" id="carousel-home">
        {# Pegamos todos os arquivos, invertemos para o mais novo vir primeiro #}
        {% set reviews = collections.all | reverse %}
        {% set count = 0 %}
        
        {% for item in reviews %}
            {# Se o arquivo tiver a variável 'album' e ainda não chegamos a 5 #}
            {% if item.data.album and count < 5 %}
                <div class="album-card">
                    <a href="{{ item.url }}">
                        <img src="{{ item.data.imagem }}" alt="Capa {{ item.data.album }}">
                    </a>
                    <div class="release-date">{{ item.data.data_lancamento }}</div>
                    <a href="{{ item.url }}" class="album-title">{{ item.data.album }}</a>
                    <a href="/artistas/{{ item.data.artista | slugify }}" class="artist-name">{{ item.data.artista }}</a>
                </div>
                {% set count = count + 1 %}
            {% endif %}
        {% endfor %}
    </div>

    <div class="old-list">
        <h2 class="section-title">Avaliações Anteriores</h2>
        <ul id="list-home" style="list-style: none; padding: 0;">
            {% set totalSkipped = 0 %}
            
            {% for item in reviews %}
                {% if item.data.album %}
                    {# Pula os 5 que já estão no carrossel #}
                    {% if totalSkipped < 5 %}
                        {% set totalSkipped = totalSkipped + 1 %}
                    {% else %}
                        <li class="old-review-item">
                            <a href="{{ item.url }}" style="display: flex; justify-content: space-between; align-items: center; padding: 18px 0; border-bottom: 1px solid #e5e2d9; text-decoration: none; color: #111; transition: 0.2s;">
                                <span><strong>{{ item.data.album }}</strong> — {{ item.data.artista }}</span>
                                <span style="font-size: 13px; color: #888; font-family: 'Inter';">{{ item.data.data_lancamento }}</span>
                            </a>
                        </li>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </ul>
    </div>

</div>

<script>
    /** * MECÂNICA DE BUSCA NA HOME
     * Filtra os cards e a lista de texto conforme o usuário digita
     */
    function searchHome() {
        const query = document.getElementById('home-search').value.toLowerCase();
        const cards = document.querySelectorAll('.album-card');
        const listItems = document.querySelectorAll('.old-review-item');

        // Filtra o Carrossel
        cards.forEach(card => {
            const text = card.innerText.toLowerCase();
            card.style.display = text.includes(query) ? "flex" : "none";
        });

        // Filtra a Lista de Anteriores
        listItems.forEach(item => {
            const text = item.innerText.toLowerCase();
            item.style.display = text.includes(query) ? "block" : "none";
        });
    }
</script>

---
templateEngineOverride: njk, md
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/Imagens/favicon.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    
    <title>Crítica do EP {{ album }} - {{ artista }}</title>
    <meta name="description" content="Crítica detalhada do EP {{ album }} de {{ artista }}.">

    <meta property="og:title" content="Review: {{ album }} (EP) - {{ artista }} - DiscoAvaliadoBR">
    <meta property="og:description" content="Crítica completa do EP {{ album }} de {{ artista }}, faixa a faixa, com crítica e contexto.">    
    <meta property="og:image" content="https://discoavaliadobr.com.br{{ imagem }}">    
    <meta property="og:url" content="https://discoavaliadobr.com.br{{ page.url }}">    
    <meta property="og:type" content="article">
    <meta property="og:site_name" content="DiscoAvaliadoBR">
    <meta property="article:published_time" content="{{ data_postagem.toISOString() if data_postagem else page.date.toISOString() }}">    
    <meta property="article:author" content="Gabriel Silva">
    <meta property="og:locale" content="pt_BR">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Review: {{ album }} (EP) - {{ artista }} - DiscoAvaliadoBR">
    <meta name="twitter:description" content="Análise completa do EP {{ album }} de {{ artista }}.">
    <meta name="twitter:image" content="https://discoavaliadobr.com.br{{ imagem }}">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="canonical" href="https://discoavaliadobr.com.br{{ page.url }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-bg: #f8f6f2;
            --accent-color: #111;
            --score-high: #111;
            --border-color: #e5e2d9;
            --text-color: #222;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: var(--primary-bg);
            color: var(--text-color);
            line-height: 1.8;
            -webkit-font-smoothing: antialiased;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 22px 50px;
            border-bottom: 1px solid var(--border-color);
            background: white;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            cursor: pointer;
            user-select: none;
            text-decoration: none;
            color: inherit;
        }

        nav a {
            margin-left: 28px;
            text-decoration: none;
            color: #222;
            font-weight: 500;
            font-size: 15px;
            transition: 0.2s;
        }

        nav a:hover { opacity: 0.6; }

        .container {
            max-width: 850px;
            margin: 60px auto;
            padding: 0 25px;
        }

        .review-header {
            display: grid;
            grid-template-columns: 280px 1fr auto;
            gap: 40px;
            align-items: center;
            margin-bottom: 50px;
            padding-bottom: 40px;
            border-bottom: 1px solid var(--border-color);
        }

        .album-cover img {
            width: 100%;
            border-radius: 12px;
            box-shadow: 0 15px 45px rgba(0,0,0,0.1);
        }

        .album-data {
            font-size: 14px;
            color: #555;
        }

        .album-data p { margin: 5px 0; }
        .album-data strong { color: #000; }

        .ep-badge {
            display: inline-block;
            background: #111;
            color: #fff;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            padding: 3px 10px;
            border-radius: 4px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .score-circle {
            font-family: 'Playfair Display', serif;
            font-size: 72px;
            font-weight: 700;
            color: var(--score-high);
            border-bottom: 5px solid var(--score-high);
            line-height: 1;
            padding-bottom: 5px;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: 48px;
            margin: 0 0 15px 0;
            line-height: 1.1;
        }

        .artist-link {
            text-decoration: none;
            color: inherit;
            border-bottom: 2px solid transparent;
            transition: 0.3s;
        }

        .artist-link:hover { border-bottom-color: #111; }

        .subtitle {
            font-size: 22px;
            color: #666;
            font-style: italic;
            margin-bottom: 30px;
            display: block;
            line-height: 1.4;
        }

        .meta-info {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 50px;
        }

        .review-content p {
            margin-bottom: 28px;
            font-size: 18px;
            text-align: justify;
            hyphens: auto;
        }

        .review-content h2 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            margin: 45px 0 20px;
            border-top: 1px solid var(--border-color);
            padding-top: 30px;
            color: #111;
        }

        .highlight-album {
            color: #111;
            font-weight: 600;
            background: #e3e0d8;
            padding: 2px 6px;
            border-radius: 4px;
        }

        .highlight-song {
            color: #111;
            font-weight: 600;
            background: #eeebe6;
            padding: 2px 6px;
            border-radius: 4px;
        }

        .share-buttons {
            margin: 30px 0;
            display: flex;
            gap: 12px;
        }

        .share-buttons a {
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            text-decoration: none;
            color: white;
            font-size: 18px;
            transition: 0.2s;
        }

        .share-buttons a:hover { transform: scale(1.1); }
        .share-buttons a:nth-child(1) { background: #25D366; }
        .share-buttons a:nth-child(2) { background: #1877F2; }
        .share-buttons a:nth-child(3) { background: #000000; }

        .tags-container {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px dashed var(--border-color);
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .tag {
            background: #eeebe6;
            color: #555;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: 0.3s;
            cursor: default;
        }

        .tag:hover { background: var(--accent-color); color: #fff; }

        footer {
            margin-top: 100px;
            padding: 60px 20px;
            text-align: center;
            background: white;
            border-top: 1px solid var(--border-color);
            color: #888;
            font-size: 13px;
        }

        @media (max-width: 768px) {
            .review-header { grid-template-columns: 1fr; text-align: center; gap: 20px; }
            .album-cover { max-width: 200px; margin: 0 auto; }
            h1 { font-size: 34px; }
            .score-circle { font-size: 60px; }
            header { padding: 15px 25px; }
        }
    </style>
</head>

<body>

<header>
    <a href="/" class="logo">DiscoAvaliadoBR</a>
    <nav>
        <a href="/">Início</a>
    </nav>
</header>

<main class="container">

    <div class="review-header">
        <div class="album-cover">
            <img src="{{ imagem }}" alt="Análise e Review do EP {{ album }} de {{ artista }}">
        </div>

        <div class="album-data">
            <span class="ep-badge">EP</span>
            <p><strong>ARTISTA:</strong> {{ artista }}</p>
            <p><strong>EP:</strong> {{ album }}</p>
            <p><strong>LANÇAMENTO:</strong> {{ data_lancamento }}</p>
            <p><strong>GÊNERO:</strong> {{ genero }}</p>
            <p><strong>DURAÇÃO:</strong> {{ duracao }}</p>
        </div>

        <div class="score-circle">
            {{ nota / 10 if nota else "0.0" }}
        </div>
    </div>

    <article>

        <h1>
            {{ album }} –
            <a href="/artistas/{{ artista | slugify }}/" class="artist-link">
                {{ artista }}
            </a>
        </h1>

        <span class="subtitle">"{{ frase_impacto }}"</span>

        <div class="share-buttons">
            <a href="#" id="share-wa" target="_blank"><i class="fab fa-whatsapp"></i></a>
            <a href="https://www.facebook.com/sharer/sharer.php?u=https://discoavaliadobr.com.br{{ page.url }}" target="_blank"><i class="fab fa-facebook-f"></i></a>
            <a href="https://twitter.com/intent/tweet?url=https://discoavaliadobr.com.br{{ page.url }}" target="_blank"><i class="fab fa-x-twitter"></i></a>
        </div>

        <div class="meta-info">
            Por Gabriel Silva - 
            <time datetime="{{ data_postagem.toISOString() if data_postagem else page.date.toISOString() }}">
                {{ data_postagem | htmlDateString if data_postagem else page.date | htmlDateString }}
            </time>
        </div>

        <div class="review-content">
            <h2>Contexto e Expectativa</h2>
            <p>{{ introducao | safe }}</p>

            <h2>Análise Crítica: Faixa a Faixa</h2>
            <p>Sem enrolação, vamos ver o que achei.</p>
            <p>{{ analise | safe }}</p>

            <h2>Conclusão e Veredito</h2>
            <p>{{ conclusao | safe }}</p>
        </div>

        <div class="tags-container">
            <span class="tag">review</span>
            <span class="tag">crítica</span>
            <span class="tag">ep</span>
            <span class="tag">{{ page.date.getFullYear() }}</span>
            <span class="tag">{{ artista }}</span>
            <span class="tag">{{ album }}</span>
            <span class="tag">{{ genero }}</span>
        </div>
    </article>
</main>

<footer>
    DiscoAvaliadoBR © 2026 • Projeto independente de crítica musical brasileira<br>
    Todos os direitos reservados.
</footer>

<script>
    window.addEventListener('load', function() {
        const shareText = encodeURIComponent(document.title + " " + window.location.href);
        const waBtn = document.getElementById('share-wa');
        if(waBtn) waBtn.href = "https://wa.me/?text=" + shareText;
    });
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Review",
  "image": "https://discoavaliadobr.com.br{{ imagem }}",
  "itemReviewed": {
    "@type": "MusicAlbum",
    "name": "{{ album }}",
    "byArtist": {
      "@type": "Person",
      "name": "{{ artista }}"
    }
  },
  "author": {
    "@type": "Person",
    "name": "Gabriel Silva"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "{{ nota / 10 if nota else 0 }}",
    "bestRating": "10",
    "worstRating": "0"
  },
  "publisher": {
    "@type": "Organization",
    "name": "DiscoAvaliadoBR"
  },
  "datePublished": "{{ data_postagem.toISOString() if data_postagem else page.date.toISOString() }}"
}
</script>

</body>
</html>

---
templateEngineOverride: njk, md
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/Imagens/favicon.png">
    <title>{{ album }} - {{ artista }} | Review e crítica do Álbum</title>
    
    <meta name="description" content="Análise detalhada do álbum {{ album }} de {{ artista }}.">
    <meta property="og:title" content="Review: {{ album }} - {{ artista }} • DiscoAvaliadoBR">
    <meta property="og:image" content="https://discoavaliadobr.com.br{{ imagem }}">
    <meta property="og:type" content="article">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root { --primary-bg: #f8f6f2; --accent-color: #111; --border-color: #e5e2d9; --text-color: #222; }
        body { margin: 0; font-family: 'Inter', sans-serif; background: var(--primary-bg); color: var(--text-color); line-height: 1.8; }
        header { display: flex; justify-content: space-between; align-items: center; padding: 15px 5%; background: #fff; border-bottom: 1px solid var(--border-color); position: sticky; top: 0; z-index: 1000; }
        .logo { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; text-decoration: none; color: #111; }
        .container { max-width: 850px; margin: 60px auto; padding: 0 25px; }
        .review-header { display: grid; grid-template-columns: 280px 1fr auto; gap: 40px; align-items: center; margin-bottom: 50px; padding-bottom: 40px; border-bottom: 1px solid var(--border-color); }
        .album-cover img { width: 100%; border-radius: 12px; box-shadow: 0 15px 45px rgba(0,0,0,0.1); }
        .score-circle { font-family: 'Playfair Display', serif; font-size: 72px; font-weight: 700; color: var(--accent-color); border-bottom: 5px solid var(--accent-color); line-height: 1; }
        .subtitle { font-size: 22px; color: #666; font-style: italic; display: block; margin-bottom: 30px; }
        .review-content h2 { font-family: 'Playfair Display', serif; font-size: 28px; margin: 45px 0 20px; border-top: 1px solid var(--border-color); padding-top: 30px; }
        .tags-container { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 10px; border-top: 1px dashed var(--border-color); padding-top: 20px; }
        .tag { background: #eeebe6; padding: 5px 15px; border-radius: 20px; font-size: 13px; text-transform: uppercase; }
        .share-buttons { margin: 30px 0; display: flex; gap: 12px; }
        .share-buttons a { width: 45px; height: 45px; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: white; text-decoration: none; }
        footer { margin-top: 100px; padding: 60px 20px; text-align: center; background: white; border-top: 1px solid var(--border-color); color: #888; font-size: 13px; }
        
        /* Search Styles */
        .search-container { position: relative; width: 250px; }
        #global-search { width: 100%; padding: 10px 15px; border-radius: 25px; border: 1px solid #ccc; outline: none; }
        #search-results-box { position: absolute; top: 50px; left: 0; right: 0; background: white; border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); max-height: 400px; overflow-y: auto; display: none; z-index: 10000; }
        .search-item-result { padding: 10px; border-bottom: 1px solid #eee; display: flex; align-items: center; gap: 10px; text-decoration: none; color: #333; }

        @media (max-width: 768px) { .review-header { grid-template-columns: 1fr; text-align: center; } .album-cover { max-width: 200px; margin: 0 auto; } }
    </style>
</head>
<body>

<header>
    <a href="/" class="logo">DiscoAvaliadoBR</a>
    <div class="search-container">
        <input type="text" id="global-search" placeholder="Buscar artista ou álbum..." onkeyup="searchSite()">
        <div id="search-results-box"></div>
    </div>
    <nav>
        <a href="/" style="text-decoration: none; color: #333; margin-right: 15px;">Início</a>
        <a href="/sobre" style="text-decoration: none; color: #333;">Sobre</a>
    </nav>
</header>

<main class="container">
    {% if artista %}
        <div class="review-header">
            <div class="album-cover">
                <img src="{{ imagem }}" alt="{{ album }} - {{ artista }}">
            </div>
            <div class="album-data">
                <p><strong>ARTISTA:</strong> {{ artista }}</p>
                <p><strong>ÁLBUM:</strong> {{ album }}</p>
                <p><strong>LANÇAMENTO:</strong> {{ data_lancamento }}</p>
                <p><strong>GÊNERO:</strong> {{ genero }}</p>
                <p><strong>DURAÇÃO:</strong> {{ duracao }}</p>
            </div>
            <div class="score-box">
                <div class="score-circle">{% if nota %}{{ nota / 10 }}{% else %}0{% endif %}</div>
            </div>
        </div>

        <article>
            {% set artista_slug = artista | slugify %}
            <h1>{{ album }} – <a href="/artistas/{{ artista_slug }}" style="color: inherit; text-decoration: none; border-bottom: 2px solid #eee;">{{ artista }}</a></h1>
            <span class="subtitle">"{{ frase_impacto }}"</span>

            <div class="share-buttons">
                <a href="#" id="share-wa" style="background: #25D366;"><i class="fab fa-whatsapp"></i></a>
                <a href="https://facebook.com/sharer/sharer.php?u=https://discoavaliadobr.com.br{{ page.url }}" style="background: #1877F2;" target="_blank"><i class="fab fa-facebook-f"></i></a>
                <a href="https://twitter.com/intent/tweet?url=https://discoavaliadobr.com.br{{ page.url }}" style="background: #000;" target="_blank"><i class="fab fa-x-twitter"></i></a>
            </div>

            <div class="review-content">
                <h2>Contexto e Expectativa</h2>
                <p>{{ introducao | safe }}</p>
                <h2>Análise Crítica</h2>
                <p>{{ analise | safe }}</p>
                <h2>Conclusão</h2>
                <p>{{ conclusao | safe }}</p>
            </div>

            <div class="tags-container">
                <span class="tag">review</span>
                <span class="tag">{{ artista }}</span>
                <span class="tag">{{ genero }}</span>
            </div>
        </article>
    {% else %}
        {{ content | safe }}
    {% endif %}
</main>

<footer>
    DiscoAvaliadoBR © 2026 • Projeto independente de crítica musical brasileira
</footer>

<script>
    // Sistema de Busca
    const searchData = [
        {% for item in collections.all %}{% if item.data.artista %}
        { title: "{{ item.data.album or item.data.artista }}", subtitle: "{{ item.data.artista }}", url: "{{ item.url }}", img: "{{ item.data.imagem }}" },
        {% endif %}{% endfor %}
    ];

    function searchSite() {
        const input = document.getElementById('global-search');
        const box = document.getElementById('search-results-box');
        const val = input.value.toLowerCase();
        if (val.length < 2) { box.style.display = 'none'; return; }
        const filtered = searchData.filter(i => i.title.toLowerCase().includes(val) || i.subtitle.toLowerCase().includes(val)).slice(0, 5);
        box.innerHTML = filtered.map(i => `<a href="${i.url}" class="search-item-result"><img src="${i.img}" width="40"><div><strong>${i.title}</strong><br><small>${i.subtitle}</small></div></a>`).join('');
        box.style.display = filtered.length ? 'block' : 'none';
    }

    // Botão WhatsApp
    window.addEventListener('load', () => {
        const btn = document.getElementById('share-wa');
        if(btn) btn.href = "https://wa.me/?text=" + encodeURIComponent(document.title + " " + window.location.href);
    });
</script>

</body>
</html>

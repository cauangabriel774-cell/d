<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/Imagens/favicon.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    
    <title>{{ artista }} - Discografia e Críticas - DiscoAvaliadoBR</title>

    <meta name="description" content="Veja análises e notas dos álbuns de {{ artista }} no DiscoAvaliadoBR.">

    <!-- Open Graph -->
    <meta property="og:type" content="profile">
    <meta property="og:title" content="{{ artista }} no DiscoAvaliadoBR">
    <meta property="og:description" content="Veja as notas e reviews dos álbuns de {{ artista }}">
    <meta property="og:image" content="{{ foto_artista }}">
    <meta property="og:url" content="{{ page.url | url }}">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #fff;
            color: #111;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            border-bottom: 1px solid #ddd;
            background: white;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            cursor: pointer;
        }

        nav a {
            margin-left: 25px;
            text-decoration: none;
            color: #111;
            font-size: 15px;
        }

        .artist-banner {
            height: 600px;
            background-image: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.7) 100%), url('{{ foto_artista }}');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: flex-end;
        }

        .artist-content {
            padding: 60px;
            color: white;
        }

        .artist-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 64px;
            margin: 0;
            text-shadow: 0 4px 20px rgba(0,0,0,0.7);
        }

        .artist-text p {
            margin-top: 10px;
            font-size: 20px;
            opacity: 0.9;
        }

        .container {
            max-width: 1100px;
            margin: 60px auto;
            padding: 0 20px;
        }

        h2 {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            margin-bottom: 40px;
            border-left: 5px solid #111;
            padding-left: 15px;
        }

        .album-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 25px;
        }

        .album-link {
            text-decoration: none;
            color: inherit;
        }

        .album-card {
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            transition: 0.25s;
        }

        .album-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.12);
        }

        .album-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .album-info {
            padding: 12px;
            text-align: center;
        }

        .score {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
        }

        .meta {
            font-size: 12px;
            color: #888;
        }

        .bio-section {
            margin-top: 100px;
            padding: 60px 0;
            border-top: 1px solid #eee;
        }

        footer {
            margin-top: 80px;
            padding: 40px;
            text-align: center;
            font-size: 13px;
            color: #777;
            border-top: 1px solid #eee;
        }

        @media (max-width: 768px) {
            .artist-banner { height: 400px; }
            .artist-text h1 { font-size: 38px; }
            .artist-content { padding: 30px; }
        }
    </style>
</head>

<body>

<header>
    <div class="logo" onclick="window.location.href='/'">DiscoAvaliadoBR</div>
    <nav>
        <a href="/">Início</a>        
    </nav>
</header>

<div class="artist-banner">
    <div class="artist-content">
        <div class="artist-text">
            <h1>{{ artista }}</h1>
            <p>{{ genero_principal }}</p>
        </div>
    </div>
</div>

<main class="container">

    <h2>Álbuns Avaliados</h2>

    <div class="album-grid">
        {% for post in collections.meusDiscos %}
            {% set lista = collections.meusDiscos | filter(attribute="data.artista", value=artista) %}

        {% for post in lista %}
            <a href="{{ post.url }}" class="album-link">
                <div class="album-card">
                    <img src="{{ post.data.imagem }}" alt="{{ post.data.album }}">
                    <div class="album-info">
                        <h3>{{ date | htmlDateString if date else page.date | htmlDateString }}</h3>
                        <div class="score">Ver review</div>
                        <div class="meta">{{ post.data.date }} • {{ post.data.genero }}</div>
                    </div>
                </div>
            </a>
            {% endif %}
        {% endfor %}
    </div>

</main>

<footer>
    DiscoAvaliadoBR © 2026 • Projeto independente de crítica musical brasileira
Todos os direitos reservados.
</footer>

</body>
</html>

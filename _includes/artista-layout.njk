<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="/Imagens/favicon.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    
    <title>{{ artista }} - Discografia e Críticas - DiscoAvaliadoBR</title>

    <meta name="description" content="Veja análises e notas dos álbuns de {{ artista }} no DiscoAvaliadoBR.">

    <meta property="og:type" content="profile">
    <meta property="og:title" content="{{ artista }} no DiscoAvaliadoBR">
    <meta property="og:description" content="Veja as notas e reviews dos álbuns de {{ artista }}">
    <meta property="og:image" content="{{ foto_artista }}">
    <meta property="og:url" content="{{ page.url | url }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --border-color: #e5e2d9;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: #fff;
            color: #111;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 22px 50px;
            border-bottom: 1px solid var(--border-color);
            background: white;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            cursor: pointer;
            user-select: none;
            text-decoration: none;
            color: inherit;
        }

        nav a {
            margin-left: 28px;
            text-decoration: none;
            color: #222;
            font-weight: 500;
            font-size: 15px;
            transition: 0.2s;
        }

        nav a:hover { opacity: 0.6; }

        .artist-banner {
            height: 600px;
            background-image: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.7) 100%), url('{{ foto_artista }}');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: flex-end;
        }

        .artist-content {
            padding: 60px;
            color: white;
        }

        .artist-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 64px;
            margin: 0;
            text-shadow: 0 4px 20px rgba(0,0,0,0.7);
        }

        .artist-text p {
            margin-top: 10px;
            font-size: 20px;
            opacity: 0.9;
        }

        .container {
            max-width: 1100px;
            margin: 60px auto;
            padding: 0 20px;
        }

        h2 {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            margin-bottom: 40px;
            border-left: 5px solid #111;
            padding-left: 15px;
        }

        .album-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 25px;
            margin-bottom: 60px;
        }

        .album-link {
            text-decoration: none;
            color: inherit;
        }

        .album-card {
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            transition: 0.25s;
        }

        .album-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.12);
        }

        .album-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .album-info {
            padding: 12px;
            text-align: center;
        }

        .album-info h3 {
            font-family: 'Playfair Display', serif;
            font-size: 15px;
            margin: 0 0 6px 0;
        }

        .score {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: 14px;
        }

        .meta {
            font-size: 12px;
            color: #888;
            margin-top: 4px;
        }

        .ep-badge {
            display: inline-block;
            background: #111;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            padding: 2px 8px;
            border-radius: 4px;
            margin-bottom: 6px;
            text-transform: uppercase;
        }

        footer {
            margin-top: 80px;
            padding: 40px;
            text-align: center;
            font-size: 13px;
            color: #777;
            border-top: 1px solid #eee;
        }

        @media (max-width: 768px) {
            .artist-banner { height: 400px; }
            .artist-text h1 { font-size: 38px; }
            .artist-content { padding: 30px; }
            header { padding: 15px 25px; }
        }
    </style>
</head>

<body>

<header>
    <a href="/" class="logo">DiscoAvaliadoBR</a>
    <nav>
        <a href="/">Início</a>
    </nav>
</header>

<div class="artist-banner">
    <div class="artist-content">
        <div class="artist-text">
            <h1>{{ artista }}</h1>
            <p>{{ genero_principal }}</p>
        </div>
    </div>
</div>

<main class="container">

    <h2>Álbuns Avaliados</h2>
    <div class="album-grid">
        {% set albumsDoArtista = collections.meusDiscos | selectattr("data.artista", "equalto", artista) | list %}
        {% for post in albumsDoArtista %}
            <a href="{{ post.url }}" class="album-link">
                <div class="album-card">
                    <img src="{{ post.data.imagem }}" alt="{{ post.data.album }}">
                    <div class="album-info">
                        <h3>{{ post.data.album }}</h3>
                        <div class="score">Ver review</div>
                        <div class="meta">{{ post.data.data_lancamento }} • {{ post.data.genero }}</div>
                    </div>
                </div>
            </a>
        {% endfor %}
    </div>

    {% set epsDoArtista = collections.meusEPs | selectattr("data.artista", "equalto", artista) | list %}
    {% if epsDoArtista.length %}
        <h2>EPs Avaliados</h2>
        <div class="album-grid">
            {% for ep in epsDoArtista %}
                <a href="{{ ep.url }}" class="album-link">
                    <div class="album-card">
                        <img src="{{ ep.data.imagem }}" alt="{{ ep.data.album }}">
                        <div class="album-info">
                            <span class="ep-badge">EP</span>
                            <h3>{{ ep.data.album }}</h3>
                            <div class="score">Ver review</div>
                            <div class="meta">{{ ep.data.data_lancamento }} • {{ ep.data.genero }}</div>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</main>

<footer>
    DiscoAvaliadoBR © 2026 • Projeto independente de crítica musical brasileira<br>
    Todos os direitos reservados.
</footer>

</body>
</html>

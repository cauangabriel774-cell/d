---
layout: layout.njk
---
<style>
    .artist-banner {
        height: 600px;
        background-image: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.7) 100%), url('{{ foto_artista }}');
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: flex-end;
    }

    .artist-content { padding: 60px; color: white; }

    .artist-text h1 {
        font-family: 'Playfair Display', serif;
        font-size: 64px;
        margin: 0;
        text-shadow: 0 4px 20px rgba(0,0,0,0.7);
    }

    .artist-text p {
        margin-top: 10px;
        font-size: 20px;
        opacity: 0.9;
        text-shadow: 0 2px 10px rgba(0,0,0,0.6);
    }

    .container-artista {
        max-width: 1100px;
        margin: 60px auto;
        padding: 0 20px;
    }

    .album-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 25px;
    }

    .album-card {
        background: white;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        transition: 0.25s;
    }

    .album-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 25px rgba(0,0,0,0.12);
    }

    .album-card img { width: 100%; height: 200px; object-fit: cover; }
    .album-info { padding: 12px; text-align: center; color: #111; }
    .album-info h3 { margin: 0 0 6px; font-size: 14px; font-weight: 600; }
    .score-small { font-family: 'Playfair Display', serif; font-weight: 700; color: #111; }

    .bio-section {
        margin-top: 80px;
        padding-top: 60px;
        border-top: 1px solid #eee;
    }

    .bio-text p { font-size: 17px; line-height: 1.8; color: #444; }

    @media (max-width: 768px) {
        .artist-banner { height: 400px; }
        .artist-text h1 { font-size: 38px; }
        .artist-content { padding: 30px; }
        .album-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
    }
</style>

<div class="artist-banner">
    <div class="artist-content">
        <div class="artist-text">
            <h1>{{ artista }}</h1>
            <p>{{ genero_principal }} • Reviewer: Gabriel Silva</p>
        </div>
    </div>
</div>

<main class="container-artista">
    <h2 style="font-family: 'Playfair Display', serif; font-size: 32px; border-left: 5px solid #111; padding-left: 15px; margin-bottom: 40px;">Álbuns Avaliados</h2>

    <div class="album-grid">
        {% for post in collections.post %}
            {% if post.data.artista == artista %}
            <a href="{{ post.url }}" style="text-decoration: none;">
                <div class="album-card">
                    <img src="{{ post.data.imagem }}" alt="{{ post.data.album }}">
                    <div class="album-info">
                        <h3>{{ post.data.album }}</h3>
                        <div class="score-small">Nota: {{ post.data.nota / 10 }}</div>
                        <div style="font-size: 12px; color: #888;">{{ post.data.data_lancamento }}</div>
                    </div>
                </div>
            </a>
            {% endif %}
        {% endfor %}
    </div>

    <section class="bio-section">
        <h2 style="font-family: 'Playfair Display', serif; font-size: 32px; margin-bottom: 20px;">Sobre o Artista</h2>
        <div class="bio-text">
            {{ content | safe }}
        </div>
    </section>
</main>

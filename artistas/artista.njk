---
layout: null
pagination:
  data: collections.artistas
  size: 1
  alias: artista
permalink: "/artistas/{{ artista.slug }}/index.html"
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{{ artista.nome }} • Discografia e Críticas • DiscoAvaliadoBR</title>
    <meta name="description" content="Veja todas as avaliações dos álbuns de {{ artista.nome }}.">

    <meta property="og:type" content="profile">
    <meta property="og:title" content="{{ artista.nome }} no DiscoAvaliadoBR">
    <meta property="og:description" content="Veja as notas e reviews dos álbuns de {{ artista.nome }}">

    {% set foto = artista.discos[0].data.imagem %}

    <meta property="og:image" content="{{ foto }}">
    <meta property="og:url" content="/artistas/{{ artista.slug }}/">

    <style>
        body { margin:0; font-family:Inter,sans-serif; background:#fff; color:#111; }

        header { display:flex; justify-content:space-between; padding:20px 40px; border-bottom:1px solid #ddd; }

        .logo { font-weight:700; font-size:24px; cursor:pointer; }

        .artist-banner {
            height: 500px;
           background: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,0.7)),
url('{{ artista.foto_artista }}');
            background-size: cover;
            background-position: center;
            display:flex;
            align-items:flex-end;
        }

        .artist-content { padding:40px; color:white; }

        .artist-content h1 {
            font-size:60px;
            margin:0;
        }

        .artist-content p {
            font-size:18px;
            opacity:0.9;
        }

        .container { max-width:1100px; margin:60px auto; padding:0 20px; }

        h2 { border-left:4px solid #111; padding-left:10px; }

        .album-grid {
            display:grid;
            grid-template-columns: repeat(auto-fill, minmax(200px,1fr));
            gap:20px;
        }

        .album-card {
            text-decoration:none;
            color:inherit;
            background:#fff;
            border-radius:8px;
            overflow:hidden;
            box-shadow:0 4px 15px rgba(0,0,0,0.08);
            transition:0.3s;
        }

        .album-card:hover {
            transform: translateY(-5px);
        }

        .album-card img {
            width:100%;
            height:200px;
            object-fit:cover;
        }

        .album-info { padding:10px; text-align:center; }

        .score { font-weight:bold; }
    </style>
</head>

<body>

<header>
    <div class="logo" onclick="window.location.href='/'">DiscoAvaliadoBR</div>
</header>

<div class="artist-banner">
    <div class="artist-content">
        <h1>{{ artista.nome }}</h1>
        <p>{{ artista.genero_principal }} • {{ artista.discos.length }} álbuns avaliados</p>
    </div>
</div>

<main class="container">

<h2>Álbuns Avaliados</h2>

<div class="album-grid">

{% for disco in artista.discos | reverse %}
    <a href="{{ disco.url }}" class="album-card">
        <img src="{{ disco.data.imagem }}" alt="{{ disco.data.album }}">
        <div class="album-info">
            <h3>{{ disco.data.album }}</h3>
            <div>{{ disco.data.data_lancamento }}</div>
        </div>
    </a>
{% endfor %}

</div>

</main>

</body>
</html>

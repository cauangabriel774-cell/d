---
layout: null
pagination:
  data: collections.artistas
  size: 1
  alias: artista
permalink: "/artistas/{{ artista.slug }}/index.html"
---

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{{ artista.nome }} - Discografia e Críticas - DiscoAvaliadoBR</title>
    <meta name="description" content="Veja todas as avaliações dos álbuns de {{ artista.nome }}.">

    <meta property="og:type" content="profile">
    <meta property="og:title" content="{{ artista.nome }} no DiscoAvaliadoBR">
    <meta property="og:description" content="Veja as notas e reviews dos álbuns de {{ artista.nome }}">
    <meta property="og:image" content="{{ artista.foto_artista }}">
    <meta property="og:url" content="/artistas/{{ artista.slug }}/">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        :root { --border-color: #e5e2d9; }

        body { margin: 0; font-family: 'Inter', sans-serif; background: #fff; color: #111; }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 22px 50px;
            border-bottom: 1px solid var(--border-color);
            background: white;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            cursor: pointer;
            user-select: none;
            text-decoration: none;
            color: inherit;
        }

        nav a {
            margin-left: 28px;
            text-decoration: none;
            color: #222;
            font-weight: 500;
            font-size: 15px;
            transition: 0.2s;
        }

        nav a:hover { opacity: 0.6; }

        .artist-banner {
            height: 500px;
            background: linear-gradient(to bottom, rgba(0,0,0,0), rgba(0,0,0,0.7)),
                url('{{ artista.foto_artista }}');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: flex-end;
        }

        .artist-content {
            padding: 60px;
            color: white;
        }

        .artist-content h1 {
            font-family: 'Playfair Display', serif;
            font-size: 64px;
            margin: 0;
            text-shadow: 0 4px 20px rgba(0,0,0,0.7);
        }

        .artist-content p {
            font-size: 20px;
            opacity: 0.9;
            margin-top: 10px;
        }

        .container {
            max-width: 1100px;
            margin: 60px auto;
            padding: 0 20px;
        }

        h2 {
            font-family: 'Playfair Display', serif;
            font-size: 32px;
            margin-bottom: 40px;
            border-left: 5px solid #111;
            padding-left: 15px;
        }

        .album-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 25px;
            margin-bottom: 60px;
        }

        .album-card {
            text-decoration: none;
            color: inherit;
            background: #fff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            transition: 0.25s;
        }

        .album-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.12);
        }

        .album-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .album-info {
            padding: 12px;
            text-align: center;
        }

        .album-info h3 {
            font-family: 'Playfair Display', serif;
            font-size: 15px;
            margin: 0 0 6px 0;
        }

        .meta {
            font-size: 12px;
            color: #888;
            margin-top: 4px;
        }

        footer {
            margin-top: 80px;
            padding: 40px;
            text-align: center;
            font-size: 13px;
            color: #777;
            border-top: 1px solid #eee;
        }

        @media (max-width: 768px) {
            .artist-banner { height: 400px; }
            .artist-content h1 { font-size: 38px; }
            .artist-content { padding: 30px; }
            header { padding: 15px 25px; }
        }
    </style>
</head>

<body>

<header>
    <a href="/" class="logo">DiscoAvaliadoBR</a>
    <nav>
        <a href="/">Início</a>
    </nav>
</header>

<div class="artist-banner">
    <div class="artist-content">
        <h1>{{ artista.nome }}</h1>
        <p>{{ artista.genero_principal }} • {{ artista.discos.length }} álbuns avaliados</p>
    </div>
</div>

<main class="container">

    <h2>Álbuns Avaliados</h2>
    <div class="album-grid">
        {% for disco in artista.discos | reverse %}
            <a href="{{ disco.url }}" class="album-card">
                <img src="{{ disco.data.imagem }}" alt="{{ disco.data.album }}">
                <div class="album-info">
                    <h3>{{ disco.data.album }}</h3>
                    <div class="meta">{{ disco.data.data_lancamento }}</div>
                </div>
            </a>
        {% endfor %}
    </div>

</main>

<footer>
    DiscoAvaliadoBR © 2026 • Projeto independente de crítica musical brasileira<br>
    Todos os direitos reservados.
</footer>

</body>
</html>
